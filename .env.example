# ─────────────────────────────────────────────────────────────────────────────
# Pan de Vida Dashboard — Salesforce Sync Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit the .env file to version control.
#
# Auth method: JWT Bearer Flow (works with MFA-enforced Salesforce orgs)
#
# HOW TO GET THESE VALUES:
# 1. SF_LOGIN_URL       → https://login.salesforce.com (production)
# 2. SF_USERNAME        → Your Salesforce login email
# 3. SF_CLIENT_ID       → Setup > App Manager > your Connected App > Consumer Key
# 4. SF_PRIVATE_KEY_PATH → Path to the server.key file generated with openssl
#
# SETUP:
#   cd scripts
#   openssl genrsa -out server.key 2048
#   openssl req -new -x509 -key server.key -out server.crt -days 3650 -subj "/C=EC/O=PanDeVida/CN=dashboard-sync"
#   → Upload server.crt to the Connected App in Salesforce (Edit > Upload Digital Certificate)
#   → In Connected App Policies: enable JWT Bearer Flow, set Permitted Users to pre-authorized
# ─────────────────────────────────────────────────────────────────────────────

SF_LOGIN_URL=https://login.salesforce.com
SF_USERNAME=your@email.com
SF_CLIENT_ID=yourConnectedAppConsumerKey
SF_PRIVATE_KEY_PATH=./server.key

# Path where the dashboard JSON will be written (relative to /scripts directory)
# Default points to the Vite public folder so the frontend can fetch it
OUTPUT_PATH=../dashboard-app/public/data/dashboard.json
